# Port number for the Express server to listen on (provided by Plesk Toolkit in production)
PORT=3000

# Environment mode (production, development, test)
NODE_ENV=development

# Allowed request Origin (production: https://feedback.thatumdonruea.com)
APP_ORIGIN=http://localhost:5173

# Secret keys for signing cookies and sessions (Minimum 32 random characters recommended)
SESSION_SECRET=your_super_secret_session_signing_key_here_at_least_32_chars
COOKIE_SECRET=your_super_secret_cookie_signing_key_here_at_least_32_chars

# Argon2id hash of the presenter PIN (Generate using: npm run hash-pin <your-pin>)
PRESENTER_PIN_HASH=$argon2id$v=19$m=65536,t=3,p=4$q+oP...

# MariaDB / MySQL Configuration
DATABASE_HOST=127.0.0.1
DATABASE_PORT=3306
DATABASE_NAME=ai_workshop_feedback
DATABASE_USER=db_user
DATABASE_PASSWORD=db_password
